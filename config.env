# ==========================================
# ⚙️ 系統全域設定檔 (config.env)
# ==========================================

# 1. 目標直播間網址
TARGET_URL="https://www.tiktok.com/@a0936931/live"

# 2. 刺探允許時間區間 (24小時制，格式 HH:MM)
PROBE_START="12:00"
PROBE_END="23:00"

# 3. 沒開播時的基礎等待間隔 (單位：秒)
PROBE_INTERVAL=120

# 4. 監控面板 Web GUI 的 Port
WEB_PORT=36591
