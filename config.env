# ==========================================
# tk_suckless - 系統全域設定檔 (config.env)
# ==========================================

# ------------------------------------------
# 1. 核心錄影設定 (Core Settings)
# ------------------------------------------
# 你的目標直播頻道網址 (Streamlink 支援的平台皆可)
TARGET_URL="https://www.twitch.tv/example_channel"


# ------------------------------------------
# 2. 網頁中控面板設定 (Web UI Settings)
# ------------------------------------------
# 面板伺服器使用的 Port，啟動後可透過 http://localhost:36591 訪問
WEB_PORT=36591


# ------------------------------------------
# 3. 雷達刺探排程 (Probe Scheduler)
# ------------------------------------------
# 戰備時段 (24小時制，支援跨夜，例如 10:00 到 03:00)
# 在這段時間內，雷達會保持警戒，高頻率檢查開播狀態
PROBE_START="10:00"
PROBE_END="03:00"

# 戰備時段的「高頻檢查間隔」基底 (秒)
# 實際等待時間會是: 60秒 + 0~20秒隨機亂數 (用來騙過平台的防機器人機制)
PROBE_INTERVAL=60

# 非戰備時段的「深度休眠時間」 (秒)
# 凌晨 03:00 ~ 10:00 期間，系統會睡多久才起來看一眼
# 3600 秒 = 1 小時 (極致省電防 Ban)
PROBE_SLEEP_DEEP=3600
